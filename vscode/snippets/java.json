  "AKit Subsystem Servo": {
    "prefix": "aksubsystem-servo",
    "description": "BearBots IO-backed servo SubsystemBase: single targetAngleDeg source of truth, clamp, instant + stepped commands",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.math.MathUtil;",
      "import edu.wpi.first.wpilibj2.command.Command;",
      "import edu.wpi.first.wpilibj2.command.SubsystemBase;",
      "import org.littletonrobotics.junction.Logger;",
      "import frc.robot.Constants;",
      "",
      "public class ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/} extends SubsystemBase {",
      "  private final ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO io;",
      "  private final ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputsAutoLogged inputs = new ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputsAutoLogged();",
      "",
      "  private double targetAngleDeg = ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.${1:kDefaultAngleDeg};",
      "",
      "  public ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO io) {",
      "    this.io = io;",
      "  }",
      "",
      "  // Single source of truth. Every setpoint, named or raw, lands here.",
      "  public void setAngleDeg(double angleDeg) {",
      "    targetAngleDeg = MathUtil.clamp(",
      "        angleDeg,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMinAngleDeg,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMaxAngleDeg);",
      "  }",
      "",
      "  // Jump to a setpoint immediately. Bind to a button:",
      "  //   button.onTrue(xxx.setAngleDegCommand(XxxConstants.kDeployedAngleDeg));",
      "  public Command setAngleDegCommand(double angleDeg) {",
      "    return runOnce(() -> setAngleDeg(angleDeg));",
      "  }",
      "",
      "  // Slew to a setpoint at a capped rate, finish within tolerance.",
      "  public Command setAngleDegSteppedCommand(double angleDeg, double degPerSec) {",
      "    double target = MathUtil.clamp(",
      "        angleDeg,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMinAngleDeg,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMaxAngleDeg);",
      "    return run(() -> {",
      "      double step = degPerSec * Constants.kLoopPeriodSecs;",
      "      double delta = MathUtil.clamp(target - targetAngleDeg, -step, step);",
      "      setAngleDeg(targetAngleDeg + delta);",
      "    }).until(() -> Math.abs(target - targetAngleDeg)",
      "        < ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kAngleToleranceDeg);",
      "  }",
      "",
      "  @Override",
      "  public void periodic() {",
      "    io.updateInputs(inputs);",
      "    Logger.processInputs(\"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}\", inputs);",
      "    Logger.recordOutput(\"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/TargetAngleDeg\", targetAngleDeg);",
      "",
      "    io.setAngleDeg(targetAngleDeg);$0",
      "  }",
      "}"
    ]
  },
  "AKit IO Motor Interface": {
    "prefix": "akio-motor",
    "description": "AdvantageKit motor IO interface with @AutoLog inputs",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import org.littletonrobotics.junction.AutoLog;",
      "",
      "public interface ${TM_FILENAME_BASE} {",
      "  @AutoLog",
      "  static class ${TM_FILENAME_BASE}Inputs {",
      "    public int encoderCount = 0;",
      "    public double positionMeters = 0.0;",
      "    public double velocityMetersPerSec = 0.0;",
      "    public double appliedVolts = 0.0;",
      "  }",
      "",
      "  default void updateInputs(${TM_FILENAME_BASE}Inputs inputs) {}",
      "",
      "  default void setVoltage(double volts) {}",
      "",
      "  default void resetEncoder() {}",
      "",
      "  default void stop() {",
      "    setVoltage(0.0);",
      "  }",
      "}"
    ]
  },
  "AKit IO XRP Motor Implementation": {
    "prefix": "akioimpl-motor-xrp",
    "description": "AdvantageKit XRP DC motor IO implementation with encoder",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.wpilibj.Encoder;",
      "import edu.wpi.first.wpilibj.xrp.XRPMotor;",
      "import static frc.robot.Constants.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Hardware.*;",
      "import static frc.robot.Constants.kMaxBatteryVoltage;",
      "",
      "public class ${TM_FILENAME_BASE} implements ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO {",
      "  private final XRPMotor motor = new XRPMotor(${1:kMotorChannel});",
      "  private final Encoder encoder = new Encoder(${2:kEncoderChannelA}, ${3:kEncoderChannelB});",
      "",
      "  private double appliedVolts = 0.0;",
      "",
      "  public ${TM_FILENAME_BASE}() {",
      "    encoder.setDistancePerPulse(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kEncoderDistancePerPulseMeters);",
      "  }",
      "",
      "  @Override",
      "  public void updateInputs(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputs inputs) {",
      "    inputs.encoderCount = encoder.get();",
      "    inputs.positionMeters = encoder.getDistance();",
      "    inputs.velocityMetersPerSec = encoder.getRate();",
      "    inputs.appliedVolts = appliedVolts;",
      "  }",
      "",
      "  @Override",
      "  public void setVoltage(double volts) {",
      "    appliedVolts = volts;",
      "    motor.set(appliedVolts / kMaxBatteryVoltage);$0",
      "  }",
      "",
      "  @Override",
      "  public void resetEncoder() {",
      "    encoder.reset();",
      "  }",
      "",
      "  @Override",
      "  public void stop() {",
      "    motor.set(0.0);",
      "  }",
      "}"
    ]
  },
  "AKit IO Sim Motor Implementation": {
    "prefix": "akioimpl-motor-sim",
    "description": "AdvantageKit sim DC motor IO implementation (voltage-driven velocity model)",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import static frc.robot.Constants.kMaxBatteryVoltage;",
      "",
      "public class ${TM_FILENAME_BASE} implements ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO {",
      "  private double appliedVolts = 0.0;",
      "  private double positionMeters = 0.0;",
      "  private double velocityMetersPerSec = 0.0;",
      "",
      "  @Override",
      "  public void updateInputs(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputs inputs) {",
      "    // Linear model: velocity scales with commanded voltage.",
      "    velocityMetersPerSec =",
      "        (appliedVolts / kMaxBatteryVoltage)",
      "            * ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kSimMaxSpeedMetersPerSec;",
      "",
      "    // Integrate velocity into position each loop tick.",
      "    positionMeters +=",
      "        velocityMetersPerSec * ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kLoopPeriodSecs;",
      "",
      "    inputs.appliedVolts = appliedVolts;",
      "    inputs.positionMeters = positionMeters;",
      "    inputs.velocityMetersPerSec = velocityMetersPerSec;",
      "    inputs.encoderCount =",
      "        (int) (positionMeters / ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kEncoderDistancePerPulseMeters);",
      "  }",
      "",
      "  @Override",
      "  public void setVoltage(double volts) {",
      "    appliedVolts = volts;$0",
      "  }",
      "",
      "  @Override",
      "  public void resetEncoder() {",
      "    positionMeters = 0.0;",
      "  }",
      "",
      "  @Override",
      "  public void stop() {",
      "    appliedVolts = 0.0;",
      "  }",
      "}"
    ]
  },
  "AKit Subsystem Motor": {
    "prefix": "aksubsystem-motor",
    "description": "BearBots IO-backed motor SubsystemBase with goal enum, @AutoLogOutput, clamp, P-control to position",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.math.MathUtil;",
      "import edu.wpi.first.wpilibj2.command.Command;",
      "import edu.wpi.first.wpilibj2.command.SubsystemBase;",
      "import org.littletonrobotics.junction.AutoLogOutput;",
      "import org.littletonrobotics.junction.Logger;",
      "import static frc.robot.Constants.kMaxBatteryVoltage;",
      "",
      "public class ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/} extends SubsystemBase {",
      "  public enum Goal {",
      "    ${1:goalA},",
      "    ${2:goalB},",
      "    ${3:goalC}",
      "  }",
      "",
      "  private final ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO io;",
      "  private final ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputsAutoLogged inputs = new ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputsAutoLogged();",
      "",
      "  @AutoLogOutput(key = \"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/Goal\")",
      "  private Goal goal = Goal.${1/(.*)/${1:/upcase}/};",
      "",
      "  public ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO io) {",
      "    this.io = io;",
      "  }",
      "",
      "  public void setGoal(Goal newGoal) {",
      "    goal = newGoal;",
      "  }",
      "",
      "  public Command setGoalCommand(Goal newGoal) {",
      "    return runOnce(() -> setGoal(newGoal));",
      "  }",
      "",
      "  public void stop() {",
      "    io.stop();",
      "  }",
      "",
      "  @Override",
      "  public void periodic() {",
      "    io.updateInputs(inputs);",
      "    Logger.processInputs(\"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}\", inputs);",
      "",
      "    double targetMeters = switch (goal) {",
      "      case ${1/(.*)/${1:/upcase}/} -> ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.k${1/(.)(.*)/${1:/upcase}${2:/downcase}/}HeightMeters;",
      "      case ${2/(.*)/${1:/upcase}/} -> ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.k${2/(.)(.*)/${1:/upcase}${2:/downcase}/}HeightMeters;",
      "      case ${3/(.*)/${1:/upcase}/} -> ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.k${3/(.)(.*)/${1:/upcase}${2:/downcase}/}HeightMeters;",
      "    };",
      "",
      "    double clampedTarget = MathUtil.clamp(",
      "        targetMeters,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMinHeightMeters,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMaxHeightMeters);",
      "",
      "    Logger.recordOutput(\"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/TargetMeters\", clampedTarget);",
      "",
      "    // P-control: drive voltage proportional to position error.",
      "    double error = clampedTarget - inputs.positionMeters;",
      "    double volts = ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kP * error;",
      "    volts = MathUtil.clamp(volts, -kMaxBatteryVoltage, kMaxBatteryVoltage);",
      "",
      "    io.setVoltage(volts);$0",
      "  }",
      "}"
    ]
  }
}