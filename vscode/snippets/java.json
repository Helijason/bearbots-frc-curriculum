  "AKit IO XRP Motor Implementation": {
    "prefix": "akioimpl-motor-xrp",
    "description": "AdvantageKit XRP DC motor IO implementation with encoder",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.wpilibj.Encoder;",
      "import edu.wpi.first.wpilibj.xrp.XRPMotor;",
      "import static frc.robot.Constants.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Hardware.*;",
      "import static frc.robot.Constants.kMaxBatteryVoltage;",
      "",
      "public class ${TM_FILENAME_BASE} implements ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO {",
      "  private final XRPMotor motor = new XRPMotor(${1:kMotorChannel});",
      "  private final Encoder encoder = new Encoder(${2:kEncoderChannelA}, ${3:kEncoderChannelB});",
      "",
      "  private double appliedVolts = 0.0;",
      "",
      "  public ${TM_FILENAME_BASE}() {",
      "    encoder.setDistancePerPulse(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kEncoderDistancePerPulseMeters);",
      "  }",
      "",
      "  @Override",
      "  public void updateInputs(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputs inputs) {",
      "    inputs.encoderCount = encoder.get();",
      "    inputs.positionMeters = encoder.getDistance();",
      "    inputs.velocityMetersPerSec = encoder.getRate();",
      "    inputs.appliedVolts = appliedVolts;",
      "  }",
      "",
      "  @Override",
      "  public void setVoltage(double volts) {",
      "    appliedVolts = volts;",
      "    motor.set(appliedVolts / kMaxBatteryVoltage);$0",
      "  }",
      "",
      "  @Override",
      "  public void resetEncoder() {",
      "    encoder.reset();",
      "  }",
      "",
      "  @Override",
      "  public void stop() {",
      "    motor.set(0.0);",
      "  }",
      "}"
    ]
  },
  "AKit IO Sim Motor Implementation": {
    "prefix": "akioimpl-motor-sim",
    "description": "AdvantageKit sim DC motor IO implementation (voltage-driven velocity model)",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import static frc.robot.Constants.kLoopPeriodSecs;",
      "import static frc.robot.Constants.kMaxBatteryVoltage;",
      "import edu.wpi.first.math.MathUtil;",
      "",
      "public class ${TM_FILENAME_BASE} implements ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO {",
      "  private double appliedVolts = 0.0;",
      "  private double positionMeters = 0.0;",
      "  private double velocityMetersPerSec = 0.0;",
      "",
      "  @Override",
      "  public void updateInputs(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputs inputs) {",
      "    // Gravity pulls the carriage down: it takes voltage just to hold position.",
      "    double effectiveVolts = appliedVolts - ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kGravityVolts;",
      "",
      "    // Linear model: velocity scales with effective voltage.",
      "    velocityMetersPerSec =",
      "        (effectiveVolts / kMaxBatteryVoltage)",
      "            * ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kSimMaxSpeedMetersPerSec;",
      "",
      "    // Integrate velocity into position each loop tick.",
      "    positionMeters +=",
      "        velocityMetersPerSec * kLoopPeriodSecs;",
      "",
      "    // Stop at the physical limits; carriage can't sink through the bottom or fly off the top.",
      "    double clamped =",
      "        MathUtil.clamp(",
      "            positionMeters,",
      "            ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMinHeightMeters,",
      "            ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMaxHeightMeters);",
      "    // Hit a hard stop: zero velocity so stall-based homing can detect it.",
      "    if (clamped != positionMeters) {",
      "      velocityMetersPerSec = 0.0;",
      "    }",
      "    positionMeters = clamped;",
      "",
      "    inputs.appliedVolts = appliedVolts;",
      "    inputs.positionMeters = positionMeters;",
      "    inputs.velocityMetersPerSec = velocityMetersPerSec;",
      "    inputs.encoderCount =",
      "        (int) (positionMeters / ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kEncoderDistancePerPulseMeters);",
      "  }",
      "",
      "  @Override",
      "  public void setVoltage(double volts) {",
      "    appliedVolts = volts;$0",
      "  }",
      "",
      "  @Override",
      "  public void resetEncoder() {",
      "    positionMeters = 0.0;",
      "    velocityMetersPerSec = 0.0;",
      "  }",
      "",
      "  @Override",
      "  public void stop() {",
      "    appliedVolts = 0.0;",
      "  }",
      "}"
    ]
  },
  "AKit Subsystem Motor": {
    "prefix": "aksubsystem-motor",
    "description": "AKit position subsystem: PIDController + ElevatorFeedforward, live PID+FF tune (LoggedNetworkNumber, bake-and-remove), setHeightMeters single source of truth, goToHeightMetersCommand for composition, stall-stop homeCommand. Trim unused parts.",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.math.MathUtil;",
      "import edu.wpi.first.math.controller.ElevatorFeedforward;",
      "import edu.wpi.first.math.controller.PIDController;",
      "import edu.wpi.first.wpilibj2.command.Command;",
      "import edu.wpi.first.wpilibj2.command.SubsystemBase;",
      "import java.util.function.BooleanSupplier;",
      "import org.littletonrobotics.junction.AutoLogOutput;",
      "import org.littletonrobotics.junction.Logger;",
      "import org.littletonrobotics.junction.networktables.LoggedNetworkNumber;",
      "import static frc.robot.Constants.kMaxBatteryVoltage;",
      "",
      "import frc.robot.Constants;",
      "",
      "public class ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/} extends SubsystemBase {",
      "  private final ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO io;",
      "  private final ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputsAutoLogged inputs = new ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputsAutoLogged();",
      "",
      "  // One controller does the math: error in, volts out. Tolerance decides \"close enough\".",
      "  private final PIDController controller = new PIDController(",
      "      Constants.currentMode == Constants.Mode.SIM",
      "          ? ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kPSim",
      "          : ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kPReal,",
      "      Constants.currentMode == Constants.Mode.SIM",
      "          ? ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kISim",
      "          : ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kIReal,",
      "      Constants.currentMode == Constants.Mode.SIM",
      "          ? ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kDSim",
      "          : ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kDReal);",
      "",
      "  // Rebuilt each loop from the tune handles below (ElevatorFeedforward gains are final).",
      "  private ElevatorFeedforward feedforward = new ElevatorFeedforward(",
      "      Constants.currentMode == Constants.Mode.SIM",
      "          ? ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kSVoltsSim",
      "          : ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kSVoltsReal,",
      "      Constants.currentMode == Constants.Mode.SIM",
      "          ? ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kGVoltsSim",
      "          : ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kGVoltsReal,",
      "      Constants.currentMode == Constants.Mode.SIM",
      "          ? ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kVVoltSecPerMeterSim",
      "          : ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kVVoltSecPerMeterReal);",
      "",
      "  // TUNE handles. Bake winners into constants, then delete these + the setPID/feedforward lines.",
      "  private final LoggedNetworkNumber kP =",
      "      new LoggedNetworkNumber(\"/Tuning/${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/kP\", controller.getP());",
      "  private final LoggedNetworkNumber kI =",
      "      new LoggedNetworkNumber(\"/Tuning/${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/kI\", controller.getI());",
      "  private final LoggedNetworkNumber kD =",
      "      new LoggedNetworkNumber(\"/Tuning/${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/kD\", controller.getD());",
      "  private final LoggedNetworkNumber kS =",
      "      new LoggedNetworkNumber(\"/Tuning/${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/kS\", feedforward.getKs());",
      "  private final LoggedNetworkNumber kG =",
      "      new LoggedNetworkNumber(\"/Tuning/${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/kG\", feedforward.getKg());",
      "  private final LoggedNetworkNumber kV =",
      "      new LoggedNetworkNumber(\"/Tuning/${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/kV\", feedforward.getKv());",
      "",
      "  private double targetMeters = ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kDefaultHeightMeters;",
      "  private boolean homing = false;",
      "",
      "  public ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO io) {",
      "    this.io = io;",
      "    controller.setTolerance(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kHeightToleranceMeters);",
      "  }",
      "",
      "  // Single source of truth. Every setpoint, named or raw, lands here.",
      "  public void setHeightMeters(double meters) {",
      "    targetMeters = MathUtil.clamp(",
      "        meters,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMinHeightMeters,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMaxHeightMeters);",
      "  }",
      "",
      "  // Jump to a height immediately. Bind to a button:",
      "  //   button.onTrue(xxx.setHeightMetersCommand(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kTopHeightMeters));",
      "  public Command setHeightMetersCommand(double meters) {",
      "    return runOnce(() -> setHeightMeters(meters));",
      "  }",
      "",
      "  // Go to a height and finish once within tolerance. Use this inside sequences.",
      "  public Command goToHeightMetersCommand(double meters) {",
      "    return run(() -> setHeightMeters(meters))",
      "        .until(this::atGoal)",
      "        .finallyDo(interrupted -> {",
      "          if (interrupted) setHeightMeters(inputs.positionMeters);",
      "        });",
      "  }",
      "",
      "  public Command homeCommand() {",
      "    // Stall-stop, but only after the carriage has actually started moving,",
      "    // otherwise the initial velocity of 0 ends it on the first loop.",
      "    BooleanSupplier stalled = new BooleanSupplier() {",
      "      boolean moved = false;",
      "      public boolean getAsBoolean() {",
      "        double v = Math.abs(inputs.velocityMetersPerSec);",
      "        if (v > ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kHomingMovingMetersPerSec) moved = true;",
      "        return moved && v < ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kHomingStallMetersPerSec;",
      "      }",
      "    };",
      "    return startRun(",
      "            () -> homing = true,",
      "            () -> io.setVoltage(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kHomingVolts))",
      "        .until(stalled)",
      "        .withTimeout(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kHomingTimeoutSecs)",
      "        .finallyDo(() -> {",
      "              io.stop();",
      "              io.resetEncoder();",
      "              setHeightMeters(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kDefaultHeightMeters);",
      "              homing = false;",
      "            });",
      "  }",
      "",
      "  @AutoLogOutput(key = \"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/AtGoal\")",
      "  public boolean atGoal() {",
      "    return controller.atSetpoint();",
      "  }",
      "",
      "  public void stop() {",
      "    io.stop();",
      "  }",
      "",
      "  @Override",
      "  public void periodic() {",
      "    io.updateInputs(inputs);",
      "    Logger.processInputs(\"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}\", inputs);",
      "",
      "    if (homing) return;   // homing owns the motor; skip PID this loop",
      "",
      "    Logger.recordOutput(\"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/TargetMeters\", targetMeters);",
      "",
      "    // TUNE: apply live gains each loop. Delete when you bake.",
      "    controller.setPID(kP.get(), kI.get(), kD.get());",
      "    feedforward = new ElevatorFeedforward(kS.get(), kG.get(), kV.get());",
      "",
      "    // Feedback (PID) + feedforward (gravity/static hold). velocity setpoint 0 = hold.",
      "    double volts = controller.calculate(inputs.positionMeters, targetMeters)",
      "        + feedforward.calculate(0.0);",
      "    volts = MathUtil.clamp(volts, -kMaxBatteryVoltage, kMaxBatteryVoltage);",
      "",
      "    io.setVoltage(volts);$0",
      "  }",
      "}",
      ""
    ]
  }
}