  "AKit IO XRP Servo Implementation": {
    "prefix": "akioimpl-servo-xrp",
    "description": "AdvantageKit XRP servo IO implementation",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.wpilibj.xrp.XRPServo;",
      "import static frc.robot.Constants.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Hardware.*;",
      "",
      "public class ${TM_FILENAME_BASE} implements ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO {",
      "  private final XRPServo servo = new XRPServo(${1:kServoChannel});",
      "",
      "  private double commandedAngleDeg = ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.${2:kDefaultAngleDeg};",
      "",
      "  @Override",
      "  public void updateInputs(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputs inputs) {",
      "    inputs.commandedAngleDeg = commandedAngleDeg;",
      "  }",
      "",
      "  @Override",
      "  public void setAngleDeg(double angleDeg) {",
      "    commandedAngleDeg = angleDeg;",
      "    servo.setAngleDeg(commandedAngleDeg);$0",
      "  }",
