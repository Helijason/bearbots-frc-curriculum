  "AKit Servo Constants": {
    "prefix": "akconstants-servo",
    "description": "BearBots per-subsystem servo constants: angle setpoints, limits, tolerance",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "public final class ${TM_FILENAME_BASE} {",
      "  private ${TM_FILENAME_BASE}() {}",
      "",
      "  // Named setpoints. Bind these directly:",
      "  //   button.onTrue(xxx.setAngleDegCommand(${TM_FILENAME_BASE}.${2:kStowedAngleDeg}));",
      "  public static final double ${2:kStowedAngleDeg} = ${3:0.0};",
      "  public static final double ${4:kRaisedAngleDeg} = ${5:90.0};",
      "",
      "  // Startup target. periodic drives here until told otherwise.",
      "  public static final double kDefaultAngleDeg = ${6:kStowedAngleDeg};",
      "",
      "  // Travel limits. setAngle clamps to this band.",
      "  public static final double kMinAngleDeg = ${7:0.0};",
      "  public static final double kMaxAngleDeg = ${8:90.0};",
      "",
      "  // Stepped-move finish window.",
      "  public static final double kAngleToleranceDeg = ${9:0.5};$0",
      "}"
    ]
  },
  "AKit IO Interface": {
    "prefix": "akio-servo",
    "description": "AdvantageKit servo IO interface with @AutoLog inputs",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import org.littletonrobotics.junction.AutoLog;",
      "",
      "public interface ${TM_FILENAME_BASE} {",
      "  @AutoLog",
      "  static class ${TM_FILENAME_BASE}Inputs {",
      "    public double commandedAngleDeg = ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.${1:kDefaultAngleDeg};",
      "  }",
      "",
      "  default void updateInputs(${TM_FILENAME_BASE}Inputs inputs) {}",
