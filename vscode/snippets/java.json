  "AKit Subsystem Servo": {
    "prefix": "aksubsystem-servo",
    "description": "BearBots IO-backed servo SubsystemBase: single targetAngleDeg source of truth, clamp, instant + stepped commands",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.math.MathUtil;",
      "import edu.wpi.first.wpilibj2.command.Command;",
      "import edu.wpi.first.wpilibj2.command.SubsystemBase;",
      "import org.littletonrobotics.junction.Logger;",
      "import frc.robot.Constants;",
      "",
      "public class ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/} extends SubsystemBase {",
      "  private final ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO io;",
      "  private final ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputsAutoLogged inputs = new ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IOInputsAutoLogged();",
      "",
      "  private double targetAngleDeg = ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.${1:kDefaultAngleDeg};",
      "",
      "  public ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}(${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}IO io) {",
      "    this.io = io;",
      "  }",
      "",
      "  // Single source of truth. Every setpoint, named or raw, lands here.",
      "  public void setAngleDeg(double angleDeg) {",
      "    targetAngleDeg = MathUtil.clamp(",
      "        angleDeg,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMinAngleDeg,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMaxAngleDeg);",
      "  }",
      "",
      "  // Jump to a setpoint immediately. Bind to a button:",
      "  //   button.onTrue(xxx.setAngleDegCommand(XxxConstants.kDeployedAngleDeg));",
      "  public Command setAngleDegCommand(double angleDeg) {",
      "    return runOnce(() -> setAngleDeg(angleDeg));",
      "  }",
      "",
      "  // Slew to a setpoint at a capped rate, finish within tolerance.",
      "  public Command setAngleDegSteppedCommand(double angleDeg, double degPerSec) {",
      "    double target = MathUtil.clamp(",
      "        angleDeg,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMinAngleDeg,",
      "        ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kMaxAngleDeg);",
      "    return run(() -> {",
      "      double step = degPerSec * Constants.kLoopPeriodSecs;",
      "      double delta = MathUtil.clamp(target - targetAngleDeg, -step, step);",
      "      setAngleDeg(targetAngleDeg + delta);",
      "    }).until(() -> Math.abs(target - targetAngleDeg)",
      "        < ${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}Constants.kAngleToleranceDeg);",
      "  }",
      "",
      "  @Override",
      "  public void periodic() {",
      "    io.updateInputs(inputs);",
      "    Logger.processInputs(\"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}\", inputs);",
      "    Logger.recordOutput(\"${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/${1:/capitalize}/}/TargetAngleDeg\", targetAngleDeg);",
      "",
      "    io.setAngleDeg(targetAngleDeg);$0",
      "  }",
      "}"
    ]
  },
  "AKit Motor Constants": {
    "prefix": "akconstants-motor",
    "description": "BearBots per-subsystem motor constants: gearing/encoder conversion, homing thresholds, PID + ElevatorFeedforward gains (real + sim), named height setpoints, limits, tolerance, sim-only speed/gravity",
    "body": [
      "// Copyright (c) $CURRENT_YEAR BearBots FRC Team 6964",
      "// Open Source Software; you can modify and/or share it under the terms of",
      "// the MIT License available in the root directory of this project.",
      "",
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "public final class ${TM_FILENAME_BASE} {",
      "  private ${TM_FILENAME_BASE}() {}",
      "",
      "  // Gearbox + encoder conversion. Measure from your mechanism, or read the datasheet.",
      "  public static final double kCountsPerMotorShaftRev = ${2:12.0};",
      "  public static final double kGearRatio = ${3:48.75};",
      "  public static final double kCountsPerOutputRev = kCountsPerMotorShaftRev * kGearRatio;",
      "  public static final double kSpoolDiameterMeters = ${4:0.020};",
      "  public static final double kOutputDistancePerRev = Math.PI * kSpoolDiameterMeters;",
      "  public static final double kEncoderDistancePerPulseMeters = kOutputDistancePerRev / kCountsPerOutputRev;",
      "",
      "  // Homing. Gentle voltage toward the hard stop; stall detected once movement starts.",
      "  public static final double kHomingVolts = ${5:-1.0};",
      "  public static final double kHomingStallMetersPerSec = ${6:0.002};",
      "  public static final double kHomingMovingMetersPerSec = ${7:0.010};",
      "  public static final double kHomingTimeoutSecs = ${8:3.0};",
      "",
      "  // Real robot PID + feedforward. Tune live via LoggedNetworkNumber, then bake in here.",
      "  public static final double kPReal = ${9:1.0};",
      "  public static final double kIReal = ${10:0.0};",
      "  public static final double kDReal = ${11:0.0};",
      "  public static final double kSVoltsReal = ${12:0.0};",
      "  public static final double kGVoltsReal = ${13:0.0};",
      "  public static final double kVVoltSecPerMeterReal = ${14:0.0};",
      "",
      "  // Sim PID + feedforward. Usually needs different gains than the real robot.",
      "  public static final double kPSim = ${15:1.0};",
      "  public static final double kISim = ${16:0.0};",
      "  public static final double kDSim = ${17:0.0};",
      "  public static final double kSVoltsSim = ${18:0.0};",
      "  public static final double kGVoltsSim = ${19:0.0};",
      "  public static final double kVVoltSecPerMeterSim = ${20:0.0};",
      "",
      "  // Named setpoints. Bind these directly:",
      "  //   button.onTrue(xxx.setHeightMetersCommand(${TM_FILENAME_BASE}.${21:kBottomHeightMeters}));",
      "  public static final double ${21:kBottomHeightMeters} = ${22:0.0};",
      "  public static final double ${23:kTopHeightMeters} = ${24:1.0};",
      "  ${25:// add more named setpoints here, one per line}",
      "",
      "  // Startup target. periodic drives here until told otherwise.",
      "  public static final double kDefaultHeightMeters = ${26:kBottomHeightMeters};",
      "",
      "  // Travel limits. setHeightMeters clamps to this band.",
      "  public static final double kMinHeightMeters = ${27:0.0};",
      "  public static final double kMaxHeightMeters = ${28:1.0};",
      "",
      "  // PID finish window.",
      "  public static final double kHeightToleranceMeters = ${29:0.005};",
      "",
      "  // Sim-only. Output speed at full voltage - measure or estimate from motor free speed + gearing.",
      "  public static final double kSimMaxSpeedMetersPerSec = ${30:0.15};",
      "",
      "  // Sim-only. Voltage needed just to hold position against gravity (kG feedforward starting point).",
      "  public static final double kGravityVolts = ${31:0.5};$0",
      "}"
    ]
  },
